{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @workspace/insta-study dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "firebase": "^11.10.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "dotenv": "^16.4.5",
    "firebase-admin": "^12.3.0",
    "stripe": "^14.25.0",
    "uuid": "^10.0.0"
  }
}